rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /recipes/{recipeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;

      allow update: if request.auth != null && (
        request.auth.uid == resource.data.createdBy
        || isFavoriteToggleOnly()
      );
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}

function favoriteCount(data) {
  return data.keys().hasAll(['favoritedBy']) ? data.favoritedBy.size() : 0;
}

function isFavoriteToggleOnly() {
  let beforeCount = favoriteCount(resource.data);
  let afterCount = favoriteCount(request.resource.data);

  return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favoritedBy'])
    && afterCount >= beforeCount - 1
    && afterCount <= beforeCount + 1;
}
